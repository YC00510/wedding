<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Wedding Invitation</title>

  <link rel="stylesheet" href="style.css"/>
</head>

<body>

<!-- HERO -->
<section class="hero">
  <div class="overlay"></div>
  <img src="images/cover.jpg" class="hero-img"/>

  <div class="hero-text">
    <h1>WE ARE GETTING MARRIED</h1>
    <h2>PING ＆ YUCHI</h2>
    <p>2027.03.20</p>

    <div class="scroll">↓ Scroll Down</div>
  </div>
</section>

<!-- INVITE -->
<section class="section">
  <h2>Invitation</h2>
  <p>
    誠摯邀請您參加我們的婚禮，<br/>
    一起見證這個重要的時刻。
  </p>
</section>

<!-- INFO -->
<section class="section card">
  <h2>Wedding Info</h2>

  <div class="info">
    <p><b>日期：</b>2027.03.20（六）</p>
    <p><b>時間：</b>11:30</p>
    <p><b>地點：</b>○○會館</p>
  </div>

  <a class="btn"
     href="https://maps.google.com"
     target="_blank">
    查看地圖
  </a>
</section>

<!-- MAP -->
<section class="section">
  <h2>Location</h2>

  <iframe
    src="https://www.google.com/maps/embed?pb="
    width="100%"
    height="250"
    style="border:0;"
    loading="lazy">
  </iframe>
</section>

<!-- GALLERY -->
<section class="section">
  <h2>Gallery</h2>

  <div class="gallery">
    <img src="images/photo1.jpg"/>
    <img src="images/photo2.jpg"/>
    <img src="images/photo3.jpg"/>
  </div>
</section>

<!-- RSVP -->
<section class="section card">
  <h2>RSVP</h2>
  <p>請點擊下方填寫出席回覆</p>

  <a class="btn"
     href="https://forms.google.com"
     target="_blank">
    我要參加
  </a>
</section>

<!-- FOOTER -->
<footer>
  <p>Thank you for celebrating with us</p>
  <p>PING ＆ YUCHI</p>
</footer>

<script src="script.js"></script>
</body>
</html>
